`timescale 1ns/1ns
module fulladd4_tb;

  // Parameters

  //Ports
  reg [3:0] IN_A;
  reg [3:0] IN_B;
  reg Cin;
  wire [3:0] Sum;
  wire Cout;

  fulladd4  fulladd4_inst (
    .IN_A(IN_A),
    .IN_B(IN_B),
    .Cin(Cin),
    .Sum(Sum),
    .Cout(Cout)
  );
  
  initial begin
    IN_A <= 4'b0111;
    IN_B <= 4'b1000;
    Cin  <= 1'b0;
    #500 $finish;
  end

  always #50 IN_A <= IN_A+1;
  always #50 IN_B <= IN_B+1;

  always #50 begin
    #1 $monitor("Time:%0t | IN_A=%d + IN_B=%d = SUM=%d (Cout=%b)", $time, IN_A, IN_B, SUM, Cout);
  end
endmodule